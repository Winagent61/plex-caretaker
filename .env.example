# Plex caretaker local configuration
#
# Copy this file to .env on the Plex Windows host and edit the values there.
# Do not commit the real .env file.

# Plex health URL. /identity is a good light-weight health check.
PLEX_URL=http://127.0.0.1:32400/identity

# Optional Plex token. Not required for a simple local /identity check in many setups,
# but included now so the repo can grow into richer API checks later.
PLEX_TOKEN=

# IMPORTANT: use a UNC path to real media on the NAS, not a mapped drive letter.
# Example: \\TatooineNAS\\Movies
PLEX_MEDIA_PATH=\\TatooineNAS\\Movies

# If Plex runs as a real Windows service, set the service name here.
# Leave blank if Plex runs as a regular user process instead.
PLEX_SERVICE_NAME=

# If Plex is not a service, the script will look for this process name.
PLEX_PROCESS_NAME=Plex Media Server

# Full path to the Plex executable, used when a process restart is needed.
# Adjust this for your machine.
PLEX_PROCESS_PATH=C:\Program Files\Plex\Plex Media Server\Plex Media Server.exe

# Safety valve: do not restart Plex more than once inside this window.
RESTART_COOLDOWN_MINUTES=30

# How long to wait after a restart before checking Plex again.
PLEX_STARTUP_DELAY_SECONDS=20

# Timeout for the local Plex HTTP check.
REQUEST_TIMEOUT_SECONDS=5

# Relative paths are resolved from the script directory.
LOG_DIR=logs
STATE_FILE=state\\plex-caretaker-state.json
